# Runook RAG billing service — environment
# Copy to .env.local for dev; set real values on the EC2 host for production.

# --- Stripe (use TEST keys until go-live) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- URLs ---
BILLING_BASE_URL=https://pay.runook.com
APP_URL=https://rag.runook.com

# --- RAGFlow engine (same host) ---
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_CONTAINER=docker-ragflow-cpu-1

# --- Storage ---
RUNOOK_STORE=dynamo
RUNOOK_DDB_TABLE=runook-rag
AWS_REGION=us-east-1

# --- Staff admin login (back-office) ---
RUNOOK_ADMIN_EMAIL=ops@runook.com
RUNOOK_ADMIN_PASSWORD=
RUNOOK_ADMIN_SESSION_SECRET=
# Optional shared token (for scripts / API automation)
RUNOOK_ADMIN_DASH_TOKEN=

# --- RAGFlow MySQL (read-only, for the account roster) ---
RAGFLOW_MYSQL_HOST=127.0.0.1
RAGFLOW_MYSQL_PORT=3306
RAGFLOW_MYSQL_USER=root
RAGFLOW_MYSQL_PASSWORD=infini_rag_flow
RAGFLOW_MYSQL_DB=rag_flow

# --- Optional email (Resend) for login details ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Runook <info@runook.com>
