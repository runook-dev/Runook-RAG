# =============================================================================
# Runook RAG Portal — Environment Variables
# =============================================================================
# Local dev: copy to .env.local and fill in. In production these are set in
# AWS Amplify → App settings → Environment variables (and baked into the SSR
# Lambda via amplify.yml).
# =============================================================================

# --- RAG engine (internal RAGFlow on EC2) -----------------------------------
# Base URL of the RAGFlow engine. Not exposed to the browser.
RAGFLOW_BASE_URL=http://localhost:9380
# System-level admin token used to provision tenants (from RAGFlow).
RAGFLOW_ADMIN_TOKEN=

# --- Storage ----------------------------------------------------------------
# "local" = JSON file under portal/.data (dev). "dynamo" = DynamoDB (prod).
RUNOOK_STORE=local
RUNOOK_DDB_TABLE=runook-rag
AWS_REGION=us-east-1

# --- Sessions ---------------------------------------------------------------
# Random 32+ char secret used to sign/identify sessions.
RUNOOK_SESSION_SECRET=change-me-in-production
