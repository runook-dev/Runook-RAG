# Runook RAG engine secrets (EC2). Copy to engine.env and fill in.
# engine.env is gitignored — never commit real secrets.

# Public hostname served by Caddy (Route 53 A record → this EC2 Elastic IP)
RAG_DOMAIN=rag-internal.runook.com

# RAGFlow image version (see https://github.com/infiniflow/ragflow/releases)
RAGFLOW_IMAGE=infiniflow/ragflow:v0.26.4

# --- RAGFlow infrastructure passwords (change all of these) ---
MYSQL_PASSWORD=change-me-mysql
MINIO_PASSWORD=change-me-minio
REDIS_PASSWORD=change-me-redis
ELASTIC_PASSWORD=change-me-elastic

# Disable self-service registration — Runook provisions tenants centrally.
REGISTER_ENABLED=0

# --- LLM / embedding provider (your key; cost billed per tenant) ---
# Configure the concrete factory/key inside RAGFlow after first boot, or via
# service_conf. This is a reminder placeholder.
LLM_API_KEY=
