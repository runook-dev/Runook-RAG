# Runook RAG engine secrets (EC2). Copy to engine.env and fill in.
# engine.env is gitignored — never commit real secrets.

# Public hostname served by Caddy (Route 53 A record → this EC2 Elastic IP)
RAG_DOMAIN=rag-internal.runook.com

# Image to run. Use the Runook-branded image built by deploy/build-image.sh
# (runook-rag:local), or the upstream image for a vanilla engine.
# To rebuild after upgrading upstream: bump the base in build-image.sh and rerun.
RAGFLOW_IMAGE=runook-rag:local

# --- RAGFlow infrastructure passwords (change all of these) ---
MYSQL_PASSWORD=change-me-mysql
MINIO_PASSWORD=change-me-minio
REDIS_PASSWORD=change-me-redis
ELASTIC_PASSWORD=change-me-elastic

# Disable self-service registration — Runook provisions tenants centrally.
REGISTER_ENABLED=0

# --- Shared LLM key (Google Gemini) ---
# Used to auto-configure Gemini (chat + embedding) for every provisioned tenant.
GEMINI_API_KEY=

# --- Optional: Google (OIDC) login ---
# Create an OAuth Web client in Google Cloud Console and authorize redirect URI:
#   https://rag.runook.com/api/v1/auth/oauth/google/callback
# Then set both values here to show a "Sign in with Google" button.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Override only if your public domain differs from rag.runook.com:
# OAUTH_GOOGLE_REDIRECT=https://rag.runook.com/api/v1/auth/oauth/google/callback

# --- LLM / embedding provider (your key; cost billed per tenant) ---
# Configure the concrete factory/key inside RAGFlow after first boot, or via
# service_conf. This is a reminder placeholder.
LLM_API_KEY=
